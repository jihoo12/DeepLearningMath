    "import random\n",
    "def f(x):\n",
    "    return (x-3) ** 2 + 4\n",
    "def dx_f(x):\n",
    "    return 2*(x-3)\n",
    "L = 0.001\n",
    "iteration = 10\n",
    "x = random.randint(-15,15)\n",
    "\n",
    "for i in range(iteration):\n",
    "    d_x = dx_f(x)\n",
    "    x -= L*d_x\n",
    "    print(x,f(x))"
   ]
